  "rpcProviders": {
    "helius": {
      "name": "Helius",
      "description": "Helius is Solana's leading RPC and data infrastructure provider, offering globally distributed nodes with sub-millisecond response times, staked connections for faster transaction confirmations, and exclusive archival methods like getTransactionsForAddress. Helius also provides LaserStream — the fastest way to stream Solana blocks, transactions, and account data via gRPC — and enhanced WebSockets for real-time on-chain event streaming.",
      "links": [
        {
          "label": "View offer",
          "url": "https://www.helius.dev/pricing"
        }
      ],
      "offer": "50% off Developer plans for Frontier builders ($49 → $24.50/mo)"
    },
    "triton-one": {
      "name": "Triton One",
      "description": "Triton One provides high-performance bare-metal RPC servers for Solana applications. Triton specializes in dedicated servers and custom deployments. Triton also offers a global shared RPC pool perfect for web3 front ends. Call Triton when you're ready to scale up. Triton's private devnet and testnet are always free.",
      "links": [
        {
          "label": "View offer",
          "url": "https://triton.one/"
        }
      ]
    },
    "fluxrpc": {
      "name": "FluxRPC",
      "description": "FluxRPC is a high-performance Solana RPC provider with Yellowstone gRPC streaming support and Lantern — a local edge-caching layer for Solana account state that delivers sub-millisecond reads at 10,000+ requests per second. Pay only for bandwidth ($0.06/GB), making it one of the most cost-effective RPC options available for high-volume applications.",
      "offer": "Developer plan at $15/month (limited-time) with access to Yellowstone streams, Lantern local RPC for faster data recall and performance, and low-latency RPC across high-volume calls.",
      "links": [
        {
          "label": "View offer",
          "url": "https://dashboard.fluxbeam.xyz/pricing"
        }
      ]
    }
  }
